# Copy to .env.self-host with `bash scripts/self-host.sh init`.
# Secret placeholders are replaced locally and must never be committed.
POSTGRES_DB=zayd
POSTGRES_USER=zayd
POSTGRES_PASSWORD=GENERATE_ON_SETUP
MINIO_ROOT_USER=zayd_storage
MINIO_ROOT_PASSWORD=GENERATE_ON_SETUP
AUTH_JWT_SECRET=GENERATE_ON_SETUP
AUTH_SESSION_SECRET=GENERATE_ON_SETUP
S3_BUCKET=zayd-private
S3_REGION=us-east-1

APP_URL=http://localhost:3100
PUBLIC_API_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3100
API_BIND_ADDRESS=127.0.0.1
API_PORT=8000
WEB_BIND_ADDRESS=0.0.0.0
WEB_PORT=3100

# local uses the bundled Ollama profile without proprietary credentials.
# cloud requires explicit provider configuration and operator-reviewed data policy.
PROVIDER_MODE=local
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=http://ollama:11434
LLM_MODEL=qwen2.5:7b
LLM_API_KEY=
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=
ENABLE_EXTERNAL_PROVIDERS=false
ENABLE_GUEST_MODE=true
LOG_LEVEL=INFO
