# Non-secret pilot deployment inputs. Keep actual values in the deployment system, not Git.
PILOT_ENVIRONMENT_ID=pilot-example
PILOT_APP_URL=https://pilot.example.invalid
PILOT_ALLOWED_ORIGINS=https://pilot.example.invalid
PILOT_S3_ENDPOINT=https://pilot-objects.example.invalid
PILOT_S3_REGION=pilot-region-1
PILOT_S3_BUCKET=pilot-private
PILOT_OFFSITE_S3_URI=s3://pilot-offsite/backups
PILOT_INVITE_ALLOWLIST_VERSION=pilot-invites-v1
PILOT_DATASET_MANIFEST=/secure/path/approved-dataset-manifest.json
PILOT_DATASET_SHA256=REPLACE_WITH_APPROVED_MANIFEST_SHA256
PILOT_DATASET_APPROVAL_ID=REPLACE_WITH_HUMAN_APPROVAL_ID

# Names only, never values. All must refer to distinct pilot-* secret-manager entries.
PILOT_DATABASE_URL_SECRET=pilot-database-url
PILOT_REDIS_URL_SECRET=pilot-redis-url
PILOT_S3_ACCESS_KEY_SECRET=pilot-s3-access-key
PILOT_S3_SECRET_KEY_SECRET=pilot-s3-secret-key
PILOT_AUTH_JWT_SECRET=pilot-auth-jwt
PILOT_AUTH_SESSION_SECRET=pilot-auth-session
PILOT_PROVIDER_TOKEN_SECRET=pilot-provider-token
PILOT_LLM_API_KEY_SECRET=pilot-llm-api-key
PILOT_EMBEDDING_API_KEY_SECRET=pilot-embedding-api-key
PILOT_INVITE_EMAIL_HASHES_SECRET=pilot-invite-email-hashes
PILOT_BACKUP_ENCRYPTION_KEY_SECRET=pilot-backup-encryption-key
PILOT_TLS_CERTIFICATE_SECRET=pilot-tls-certificate
PILOT_TLS_PRIVATE_KEY_SECRET=pilot-tls-private-key
PILOT_PROMETHEUS_VOLUME=pilot-prometheus-data
PILOT_BACKUP_VOLUME=pilot-backup-staging
